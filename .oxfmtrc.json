{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "arrowParens": "always",
  "experimentalSortImports": {},
  "ignorePatterns": [
    "package.json",
    "node_modules/**",
    "dist/**",
    "dist*/**",
    "CLAUDE.md",
    "AGENTS.md",
    "opencode.jsonc",
    ".claude/**",
    ".opencode/**"
  ],
  "overrides": [
    {
      "files": ["**/*.json", "**/*.jsonc"],
      "options": {
        "trailingComma": "none"
      }
    }
  ]
}
