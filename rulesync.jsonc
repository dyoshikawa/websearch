{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/config-schema.json",

  "targets": {
    "claudecode": {
      "rules": true,
      "commands": true,
      "mcp": true,
      "subagents": true,
      "skills": true,
      "hooks": true
    },
    "opencode": {
      "rules": true,
      "commands": true,
      "mcp": true,
      "subagents": true
    }
  },

  "outputRoots": ["."],

  "delete": true,
  "verbose": true,
  "silent": false,

  "simulateCommands": true,
  "simulateSubagents": true,
  "simulateSkills": true,

  "gitignoreTargetsOnly": false
}
